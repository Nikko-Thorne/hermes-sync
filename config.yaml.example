# Hermes Sync Configuration
# https://github.com/Nikko-Thorne/hermes-sync
#
# Copy this file to ~/.hermes/plugins/hermes-sync/config.yaml
# and fill in your repo details.

# Backend: "github"
backend: github

# Your private GitHub repo for sync state
# HTTPS: https://github.com/you/hermes-sync-state.git
# SSH:   git@github.com:you/hermes-sync-state.git
repo_url: ""

# Sync interval in seconds (default: 60)
sync_interval: 60

# Auto-resolve merge conflicts (default: true)
auto_resolve_conflicts: true

# Platforms to sync to (auto-detected if empty)
# platforms: [linux, macos]

# What to sync (default: skills + memories)
sync_skills: true
sync_memories: true
sync_cron: false

# GitHub Personal Access Token (NOT recommended — use GH_TOKEN env var instead)
# token: ""
